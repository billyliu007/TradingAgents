# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Google Drive integration (optional)
GDRIVE_INVESTMENT_FOLDER_ID=   # Drive folder ID for the "Investment" parent folder
# Option A – file path (local dev, file must be gitignored)
GDRIVE_SERVICE_ACCOUNT_JSON=Google/your-service-account.json
# Option B – paste full JSON content (recommended for cloud/Render; takes priority over file path)
# GDRIVE_SERVICE_ACCOUNT_JSON_CONTENT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
