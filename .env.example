# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
MOONSHOT_API_KEY=
# China console keys: use provider "Kimi (China)" in the UI, or set:
# MOONSHOT_API_BASE=https://api.moonshot.cn/v1
# (International default is https://api.moonshot.ai/v1 — keys are not interchangeable.)

# PostgreSQL cache (Neon or any Postgres URL).
# When set, completed analyses are stored and replayed on duplicate requests.
DATABASE_URL=

# Comma-separated browser origins allowed to call the API (default * = any). Example: http://localhost:3000,http://127.0.0.1:5500
# TRADINGAGENTS_CORS_ORIGINS=*

# Append JSONL records for every LLM call (prompts + usage when available). Default file: <TRADINGAGENTS_RESULTS_DIR>/prompt_audit.jsonl
# TRADINGAGENTS_PROMPT_AUDIT=1
# TRADINGAGENTS_PROMPT_AUDIT_FILE=/absolute/or/relative/path/prompt_audit.jsonl
# TRADINGAGENTS_PROMPT_AUDIT_MAX_CHARS=50000

# Admin settings UI at /admin (browser session cookie). Empty password disables login.
TRADINGAGENTS_ADMIN_USER=billyliu
TRADINGAGENTS_ADMIN_PASSWORD=
# Optional: signing key for session cookies (defaults to password if unset).
# TRADINGAGENTS_ADMIN_SESSION_SECRET=
